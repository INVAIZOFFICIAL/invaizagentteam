{
  "name": "invaiz-luffy-squad",
  "version": "0.1.0",
  "private": true,
  "description": "INVAIZ 루피 사단 — 원피스 캐릭터 AI 에이전트 팀 자동화 시스템",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:luffy": "tsx watch src/agents/luffy/index.ts",
    "dev:nami": "tsx watch src/agents/nami/index.ts",
    "dev:zoro": "tsx watch src/agents/zoro/index.ts",
    "dev:usopp": "tsx watch src/agents/usopp/index.ts",
    "dev:sanji": "tsx watch src/agents/sanji/index.ts",
    "dev:chopper": "tsx watch src/agents/chopper/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "test": "jest",
    "test:discord": "tsx scripts/test-agents.ts --discord",
    "test:notion": "tsx scripts/test-agents.ts --notion",
    "cron:list": "tsx scripts/cron-list.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@notionhq/client": "^2.2.15",
    "@sendgrid/mail": "^8.1.3",
    "discord.js": "^14.16.3",
    "node-cron": "^3.0.3",
    "playwright": "^1.50.1",
    "puppeteer": "^23.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
